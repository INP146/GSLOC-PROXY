# 本地运行配置模板；复制为 .env 后会被 run-local.py / run-local.sh 自动加载。
# 这里全是进程启动参数，不是代理业务配置。

# 代理端口：客户端/sing-box 指向这个端口。默认 8082，避开常见占用。
GSLOC_PROXY_PORT=8082

# 管理 Web/API：浏览器打开 http://127.0.0.1:${GSLOC_MANAGE_PORT}/
# 只本机访问用 127.0.0.1；需要手机访问 Web/CA 时可设为 0.0.0.0，但只在可信局域网使用。
GSLOC_MANAGE_HOST=127.0.0.1
GSLOC_MANAGE_PORT=8090

# 管理控制台登录。默认用户名 admin；密码为空时禁用登录，便于纯本机实验。
# 监听 0.0.0.0 或可信局域网访问时，务必设置强密码。
GSLOC_MANAGE_USER=admin
GSLOC_MANAGE_PASSWORD=

# 可选：本机静态代理策略覆盖。留空时默认使用 ./policy.json；文件不存在时使用代码内置默认策略。
GSLOC_POLICY_PATH=

# Web 控制台保存后的运行时状态。留空时默认使用 ./state.json；文件不存在时使用代码内置默认状态。
GSLOC_STATE_PATH=

# Web 控制台请求重启时使用的标记文件。留空时默认使用 ./.restart-requested。
GSLOC_RESTART_FLAG=

# mitmproxy 自己的 CA/运行配置目录。留空时默认使用 ./.mitmproxy，避免使用 ~/.mitmproxy。
MITMPROXY_CONF_DIR=

# gsloc-proxy 统一日志级别。影响 Web/API 中保留的真实日志。
# 可选：debug, info, success, warning, error
GSLOC_LOG_LEVEL=info

# 终端输出的最低日志级别。留空时跟随 GSLOC_LOG_LEVEL；想让 Web 详细、终端安静可设 warning。
GSLOC_TERMINAL_LOG_LEVEL=

# 可选：持久文件日志。留空表示不写文件；建议本地开发用 ./logs/gsloc-proxy.log。
GSLOC_LOG_FILE=

# 文件日志最低级别、格式与轮转。
# GSLOC_LOG_FORMAT 可选：jsonl, text
GSLOC_FILE_LOG_LEVEL=info
GSLOC_LOG_FORMAT=jsonl
GSLOC_LOG_MAX_BYTES=10485760
GSLOC_LOG_BACKUP_COUNT=5
