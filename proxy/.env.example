# 本地运行配置模板；复制为 .env 后会被 run-local.sh 自动加载。
# 这里全是进程启动参数，不是代理业务配置。

# 代理端口：客户端/sing-box 指向这个端口。默认 8080；本项目建议用 8082 避开常见占用。
GSLOC_PROXY_PORT=8082

# 管理 Web/API：浏览器打开 http://127.0.0.1:${GSLOC_MANAGE_PORT}/
# 只本机访问用 127.0.0.1；需要手机访问 Web/CA 时可设为 0.0.0.0，但只在可信局域网使用。
GSLOC_MANAGE_HOST=127.0.0.1
GSLOC_MANAGE_PORT=8090

# 可选：本机静态代理策略覆盖。留空时默认使用 ./policy.json；文件不存在时使用代码内置默认策略。
GSLOC_POLICY_PATH=

# Web 控制台保存后的运行时状态。留空时默认使用 ./state.json；文件不存在时使用代码内置默认状态。
GSLOC_STATE_PATH=

# mitmproxy 自己的 CA/运行配置目录。留空时默认使用 ./.mitmproxy，避免使用 ~/.mitmproxy。
MITMPROXY_CONF_DIR=
